# ──────────────────────────────────────────────
#  Th3rdAI Code Companion — Spline 3D Scenes
# ──────────────────────────────────────────────
#
#  Copy this file to .env and add your Spline scene URLs.
#  See SPLINE_GUIDE.md for setup instructions.
#
#  URLs look like: https://prod.spline.design/ABC123/scene.splinecode

# Optional: when the server uses CC_API_SECRET and you open the app from a non-loopback URL
# (e.g. http://192.168.x.x:8900), set this to the same value so the built SPA sends X-CC-API-Key.
# Do not commit real secrets. Prefer opening http://localhost:PORT or http://127.0.0.1:PORT instead.
# VITE_CC_API_KEY=

# Optional: Ollama Cloud Bearer token. Wins over Settings (.cc-config.json) when set.
# OLLAMA_API_KEY=

# Optional: Docling-serve API key. Wins over Settings → docling.apiKey when set.
# DOCLING_API_KEY=

# Optional: GitHub PAT when no token is stored in Settings (clone / API).
# GITHUB_TOKEN=

# Multi-account: matches githubTokens[] order in .cc-config.json (first = _0, second = _1).
# GITHUB_TOKEN_0=
# GITHUB_TOKEN_1=

# MCP stdio clients (e.g. Nano Banana): put GEMINI_API_KEY, STITCH_API_KEY, etc. here.
# They override per-client env blocks in .cc-config.json when the same variable name is set.
#
# Two GitHub MCP stdio servers with different PATs — use client id (hyphens → underscores):
# MCP_github_3rdaai_admin__GITHUB_PERSONAL_ACCESS_TOKEN=
# MCP_github_3rdai_bill__GITHUB_PERSONAL_ACCESS_TOKEN=
#
# Electron also loads ${CC_DATA_DIR}/.env (e.g. CodeCompanion-Data/.env or Application Support/code-companion/.env).

VITE_SPLINE_SPLASH_SCENE=https://prod.spline.design/YOUR_SPLASH_SCENE/scene.splinecode
VITE_SPLINE_HEADER_SCENE=https://prod.spline.design/YOUR_HEADER_SCENE/scene.splinecode
VITE_SPLINE_EMPTY_STATE_SCENE=https://prod.spline.design/YOUR_EMPTY_STATE_SCENE/scene.splinecode
