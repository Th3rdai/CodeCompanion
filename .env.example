# ──────────────────────────────────────────────
#  Th3rdAI Code Companion — Spline 3D Scenes
# ──────────────────────────────────────────────
#
#  Copy this file to .env and add your Spline scene URLs.
#  See SPLINE_GUIDE.md for setup instructions.
#
#  URLs look like: https://prod.spline.design/ABC123/scene.splinecode

# Optional: when the server uses CC_API_SECRET and you open the app from a non-loopback URL
# (e.g. http://192.168.x.x:8900), set this to the same value so the built SPA sends X-CC-API-Key.
# Do not commit real secrets. Prefer opening http://localhost:PORT or http://127.0.0.1:PORT instead.
# VITE_CC_API_KEY=

# Optional: Ollama Cloud Bearer token when not set in Settings (.cc-config.json → ollamaApiKey).
# Picked up by server.js on startup (same as exporting in your shell). Do not commit real keys.
# OLLAMA_API_KEY=

VITE_SPLINE_SPLASH_SCENE=https://prod.spline.design/YOUR_SPLASH_SCENE/scene.splinecode
VITE_SPLINE_HEADER_SCENE=https://prod.spline.design/YOUR_HEADER_SCENE/scene.splinecode
VITE_SPLINE_EMPTY_STATE_SCENE=https://prod.spline.design/YOUR_EMPTY_STATE_SCENE/scene.splinecode
