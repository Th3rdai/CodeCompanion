# ──────────────────────────────────────────────
#  Th3rdAI Code Companion — Spline 3D Scenes
# ──────────────────────────────────────────────
#
#  Paste your Spline scene URLs below.
#  Get them from: spline.design → Share → Copy Link
#  URLs look like: https://prod.spline.design/ABC123/scene.splinecode
#
#  Leave blank to use gradient fallbacks (app works fine without these).

VITE_SPLINE_SPLASH_SCENE=
VITE_SPLINE_HEADER_SCENE=
VITE_SPLINE_EMPTY_STATE_SCENE=

# OpenAI API Key for gitnexus wiki generation
OPENAI_API_Key= <your openai api key>

# Anthropic API Key
ANTHROPIC_API_KEY= <your anthropic api key>

# OpenRouter API Key or other API Key for gitnexus wiki generation
OPEN_ROUTER_API_KEY=  <your open router api key>

#Apple ID and App Specific Password
APPLE_ID= 
APPLE_APP_SPECIFIC_PASSWORD= 
APPLE_TEAM_ID= 
MAC_DISTRIBUTION_SIGN=  <your mac distribution sign>
MAC_CODESIGN_IDENTITY=  <your mac code sign identity>
MAC_NOTARIZE=  <your mac notarize>

# Host
HOST=0.0.0.0 <or your host ip address>

# ── Code Companion (moved from .cc-config.json — keep this file out of git)
OLLAMA_API_KEY= <your ollama api key>
GEMINI_API_KEY= <your gemini api key>
STITCH_API_KEY= <your stitch api key>

# Matches githubTokens[] order in Settings (first account = _0, second = _1)
GITHUB_TOKEN_0= <your github token 0>
GITHUB_TOKEN_1= <your github token 1>

# CodeCompanion-Data MCP stdio (two GitHub MCP servers — matches client id in .cc-config.json)
MCP_github_3rdaai_admin__GITHUB_PERSONAL_ACCESS_TOKEN= <your github mcp token 0>
MCP_github_3rdai_bill__GITHUB_PERSONAL_ACCESS_TOKEN= <your github mcp token 1>

# Google OAuth2 Client ID and Client Secret
GOOGLE_CLIENT_ID= <your google client id>
GOOGLE_CLIENT_SECRET= <your google client secret>

# Google API Key and Gemini API Key
GOOGLE_API_KEY= <your google api key>
GEMINI_API_KEY= <your gemini api key>
