*.pyc
__pycache__/

# Backups
*.backup

# Archives
!ARCHIVES/

# AI agent/IDE config directories
.agent/
# Claude Code — team files are force-added (git add -f); rest of .claude/ stays local
.claude/
# Optional MCP overrides (copy from .mcp.json.example)
.mcp.local.json
.codebuddy/
.codex/
.continue/
