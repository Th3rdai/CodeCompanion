{
  "name": "code-companion",
  "version": "1.0.0",
  "description": "Th3rdAI Code Companion — powered by local Ollama LLMs",
  "license": "MIT",
  "author": {
    "name": "James Avila",
    "email": "james@th3rdai.com",
    "url": "https://github.com/Th3rdai"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "node server.js",
    "dev:client": "npx vite",
    "dev": "npx vite & node server.js",
    "build": "npx vite build",
    "preview": "npx vite build && node server.js",
    "electron:dev": "electron electron/main.js",
    "electron:build": "npm run build && electron-builder --config electron-builder.config.js --publish never",
    "electron:build:mac": "npm run build && electron-builder --mac --config electron-builder.config.js --publish never",
    "electron:build:win": "npm run build && electron-builder --win --config electron-builder.config.js --publish never",
    "electron:build:linux": "npm run build && electron-builder --linux --config electron-builder.config.js --publish never",
    "test": "npx playwright test",
    "test:ui": "npx playwright test tests/ui --project=chromium",
    "test:e2e": "npx playwright test tests/e2e --project=chromium",
    "test:unit": "node --test tests/unit/*.test.js tests/rate-limit.test.js tests/mcp-security.test.js tests/tone-validation.test.js tests/ui-labels.test.js",
    "mcp": "node mcp-server.js",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node mcp-server.js"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@splinetool/react-spline": "^4.1.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "helmet": "^8.1.0",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "mermaid": "^11.13.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "uuid": "^9.0.0",
    "vite": "^7.3.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "yauzl": ">=3.2.1"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  }
}
